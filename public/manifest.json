{
  "manifest_version": 3,
  "name": "FocusSpark",
  "version": "1.0.0",
  "description": "AI-powered focus and productivity enhancement tool",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open FocusSpark",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "notifications",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "ws://127.0.0.1:8000/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; img-src 'self' data: blob: http://127.0.0.1:8000 http://localhost:8000 https:"
  }
}
